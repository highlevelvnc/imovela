# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Imovela
APP_TAGLINE=Lead intelligence imobiliária
APP_ENV=development          # development | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
LOG_FILE=logs/imovela.log

# Signature appended to outreach messages drafted in the dashboard.
# Per-tenant — leave blank for a neutral closing.
CONTACT_SIGNATURE=Cumprimentos

# ─── Database ─────────────────────────────────────────────────────────────────
# Phase 1: SQLite (local)
DATABASE_URL=sqlite:///data/imovela.db

# Phase 2: PostgreSQL (uncomment + set when migrating)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/imovela

# ─── Proxy Configuration ──────────────────────────────────────────────────────
USE_PROXIES=false
# Comma-separated list of proxies — format: http://user:pass@host:port
PROXY_LIST=

# ─── Scraping ─────────────────────────────────────────────────────────────────
SCRAPE_DELAY_MIN=2.0         # minimum seconds between requests
SCRAPE_DELAY_MAX=6.0         # maximum seconds between requests
MAX_RETRIES=3
REQUEST_TIMEOUT=30
HEADLESS_BROWSER=true        # set false for visual debugging of Playwright

# ─── Target Zones (comma-separated) ──────────────────────────────────────────
# Edit per client. Typical Lisboa-area portfolio below.
TARGET_ZONES=Lisboa,Cascais,Sintra,Almada,Seixal,Sesimbra,Oeiras,Amadora,Loures,Odivelas

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULE_TIME=08:00          # daily run time (HH:MM local)
SCHEDULE_ENABLED=true

# ─── Scoring ──────────────────────────────────────────────────────────────────
HOT_SCORE_THRESHOLD=60
WARM_SCORE_THRESHOLD=40

# ─── Notifications — Email (optional) ────────────────────────────────────────
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ─── Notifications — Telegram (optional) ─────────────────────────────────────
ALERT_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
